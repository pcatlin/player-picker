{
  "expo": {
    "name": "PlayerPicker",
    "slug": "PlayerPicker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/playerpicker-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#2b8cff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paulcatlin.playerpicker",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/playerpicker-icon.png",
        "backgroundColor": "#2b8cff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.paulcatlin.playerpicker"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "be58dd0c-509b-45fa-896c-f08be67873ff"
      }
    },
    "owner": "paulcatlin"
  }
}
