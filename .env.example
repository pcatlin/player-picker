# RevenueCat (required for dev builds with IAP)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# App Store review contact (required for `eas metadata:push` / iOS submit metadata)
# Use international format for phone, e.g. +44 7xxx xxxxxx
STORE_REVIEW_EMAIL=
STORE_REVIEW_PHONE=

